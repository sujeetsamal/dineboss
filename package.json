{
  "name": "dineboos",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron": "electron .",
    "start-all": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "dist": "npm run build && electron-builder --publish never",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "dist:win-portable": "npm run build && electron-builder --win portable --publish never",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@vercel/speed-insights": "^2.0.0",
    "firebase": "^12.12.0",
    "framer-motion": "^12.38.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.8.1",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "electron-builder": "^24.9.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "wait-on": "^9.0.5",
    "webpack-cli": "^7.0.2"
  },
  "build": {
    "appId": "com.dineboss.app",
    "productName": "DineBoss",
    "artifactName": "DineBoss-Setup.exe",
    "copyright": "© Kalinga Aerospace Private Limited",
    "publish": null,
    "directories": {
      "output": "dist",
      "buildResources": "public"
    },
    "files": [
      "out/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "icon": "public/favicon.ico"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DineBoss",
      "deleteAppDataOnUninstall": false,
      "installerIcon": "public/favicon.ico",
      "uninstallerIcon": "public/favicon.ico",
      "installerHeaderIcon": "public/favicon.ico",
      "allowElevation": true,
      "perMachine": false,
      "runAfterFinish": true,
      "unicode": true,
      "differentialPackage": true
    },
    "portable": {
      "artifactName": "DineBoss-Portable.exe"
    }
  }
}
